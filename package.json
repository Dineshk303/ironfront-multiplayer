{
  "name": "ironfront-multiplayer",
  "version": "1.0.0",
  "private": true,
  "description": "WebGL multiplayer vehicle arena for up to 8 players",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "check": "node --check server.js && node --check public/game.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "express": "4.21.2",
    "socket.io": "4.8.1",
    "three": "0.179.1"
  }
}
